APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=spihub
DB_USER=root
DB_PASS=

# Leave empty on Railway. Use only for local setups that rely on mysql socket.
DB_SOCKET=

# For production with Netlify frontend, set allow_all to false and whitelist your site.
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
